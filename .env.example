# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# Supabase (Project Settings -> API)
# SUPABASE_URL and SUPABASE_ANON_KEY are safe to expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY is a SECRET (bypasses row-level security) — server only.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Optional override for the ROMATSA source
# ZONES_SOURCE_URL=https://flightplan.romatsa.ro/init/static/zone_restrictionate_uav.json
